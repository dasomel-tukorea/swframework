### [XSS-Filter-2] POST /students/filter-test — 필터가 파라미터 sanitize 후 Controller 진입
# XssEscapeFilter 가 /students/filter-test 에 등록됨
# → Controller 의 filterTest() 메서드에는 HtmlUtils.htmlEscape() 호출 없음
# → 그런데도 userInput 이 이미 이스케이프된 상태 (필터가 처리)
POST {{baseUrl}}/students/filter-test
Content-Type: application/x-www-form-urlencoded

userInput=%3Cscript%3Ealert%28%27Filter-XSS%27%29%3C%2Fscript%3E

> {%
client.test("200 OK", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("필터 레벨 이스케이프 — th:utext 로 출력해도 &lt;script&gt; 로 표시됨", function() {
    // XssEscapeFilterConfig 의 XssEscapeFilter 가 파라미터 sanitize
    // → th:utext 로 출력해도 <script> 실행 안 됨
    client.assert(response.body.includes("&lt;script&gt;"), "필터 레벨 이스케이프 기대 — Controller 코드에 escape() 없음을 확인");
});
client.test("Controller 코드에 수동 escape 호출 없이 방어됨 (관심사 분리)", function() {
    // 이 테스트는 동작 결과로만 확인 가능 — StudentController.filterTest() 소스 참고
    client.assert(!response.body.includes("<script>alert"), "스크립트 태그 미실행 확인");
});
%}

###

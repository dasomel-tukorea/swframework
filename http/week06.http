Content-Type: application/x-www-form-urlencoded

name=최지수&studentId=202300005&email=

> {%
client.test("302 Redirect (이메일 없어도 등록 성공)", function() {
    client.assert(response.status === 302, "302 Redirect 기대");
});
%}


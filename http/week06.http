# ══════════════════════════════════════════════════════════════
# Stored XSS 방어 — DB에 저장된 악성 데이터가 화면에 표시될 때
# th:text → &lt; &gt; 로 변환 (방어), th:utext → 태그 그대로 (위험)
# 순서대로 실행: 등록 → API 확인 → 목록 HTML 확인 → 상세 HTML 확인
# ══════════════════════════════════════════════════════════════

### [StoredXSS-1] POST /students — HTML 태그가 포함된 이름으로 학생 등록
# <b>XSS테스트</b> = 14자 → @Size(max=20) 통과, studentId 9자리 통과
# URL 인코딩: < → %3C, > → %3E, / → %2F
POST {{baseUrl}}/students
Content-Type: application/x-www-form-urlencoded

name=%3Cb%3EXSS%ED%85%8C%EC%8A%A4%ED%8A%B8%3C%2Fb%3E&studentId=202399998&email=

> {%
client.test("302 Redirect (등록 성공)", function() {
    client.assert(response.status === 302, "302 Redirect 기대 — 200이면 검증 실패");
});
client.globals.set("xssStudentLocation", response.headers.valueOf("Location"));
%}

###

### [StoredXSS-2] GET /api/students — DB에 원본 태그 저장 확인
# JSON API는 HTML 이스케이프 없음 → 원본 <b>XSS테스트</b> 그대로 반환
GET {{baseUrl}}/api/students
Accept: application/json

> {%
client.test("상태코드 200", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("DB에 원본 HTML 태그가 저장됨 (JSON은 이스케이프 안 함)", function() {
    const names = response.body.map(function(s) { return s.name; });
    const found = names.some(function(n) { return n.includes("<b>"); });
    client.assert(found, "JSON 응답에서 <b> 태그 포함된 이름 기대 — StoredXSS-1이 먼저 실행됐어야 함");
});
%}

###

### [StoredXSS-3] GET /students — 목록 HTML에서 th:text 이스케이프 확인
# th:text가 < → &lt;, > → &gt; 로 변환 → Stored XSS 방어됨
GET {{baseUrl}}/students
Accept: text/html

> {%
client.test("상태코드 200", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("목록에서 &lt;b&gt; 이스케이프 확인 (th:text 방어)", function() {
    // th:text → <b>XSS테스트</b>가 &lt;b&gt;XSS테스트&lt;/b&gt;로 출력
    client.assert(response.body.includes("&lt;b&gt;"), "&lt;b&gt; 이스케이프 기대 — 목록에서 Stored XSS 방어됨");
});
client.test("원본 <b> 태그가 HTML에 직접 없음 (실행 방지)", function() {
    // &lt;b&gt; 안에도 <b>가 포함되므로 XSS테스트라는 텍스트 주변으로 확인
    // 이스케이프 후: &lt;b&gt;XSS테스트&lt;/b&gt;
    // 이스케이프 전(위험): <b>XSS테스트</b> → 굵게 렌더링됨
    const escapedPresent = response.body.includes("&lt;b&gt;XSS");
    client.assert(escapedPresent, "이스케이프된 형태(&lt;b&gt;XSS)로 출력되어야 함");
});
%}

###

# ══════════════════════════════════════════════════════════════
# Lab 05 — XSS 방어 4가지 방법 비교 (/students/xss-test)
#
# 방법 ①  th:utext               → 이스케이프 없음 (위험)
# 방법 ②  th:text                → Thymeleaf 뷰 레이어 자동 이스케이프
# 방법 ③  HtmlUtils.htmlEscape() → Controller(Java) 레이어 수동 이스케이프 (모든 HTML 차단)
# 방법 ④  OWASP HTML Sanitizer   → allowlist 방식, 안전한 HTML 보존 + 위험 태그 제거
# 방법 ⑤  XssEscapeFilter        → 서블릿 필터 레벨 자동 sanitize (/students/filter-test)
# ══════════════════════════════════════════════════════════════

### [XSS-Manual-1] GET /students/xss-test — 비교 폼
GET {{baseUrl}}/students/xss-test
Accept: text/html

> {%
client.test("200 OK", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("XSS 비교 페이지 제목", function() {
    client.assert(response.body.includes("4가지 방법"), "4가지 방법 비교 제목 기대");
});
%}

###

### [XSS-Manual-2] POST /students/xss-test — script 태그: 3가지 방법 모두 이스케이프 확인
# userInput URL 인코딩: <script>alert('XSS')</script>
# < → %3C, > → %3E, ' → %27, ( → %28, ) → %29
POST {{baseUrl}}/students/xss-test
Content-Type: application/x-www-form-urlencoded

userInput=%3Cscript%3Ealert%28%27XSS%27%29%3C%2Fscript%3E

> {%
client.test("200 OK", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("② th:text — &lt;script&gt; 이스케이프됨 (Thymeleaf 자동 방어)", function() {
    client.assert(response.body.includes("&lt;script&gt;"), "th:text 이스케이프 기대");
});
client.test("③ 수동 이스케이프 — &lt;script&gt; 가 2회 이상 나타남 (th:text + manual)", function() {
    const count = (response.body.match(/&lt;script&gt;/g) || []).length;
    client.assert(count >= 2, "th:text + 수동 이스케이프 각 1회 기대, 실제: " + count);
});
client.test("④ OWASP Sanitizer — <script> 태그 완전 제거됨", function() {
    // OWASP sanitize 후 th:utext로 출력: <script>는 allowlist에 없으므로 제거
    // 응답 HTML에 <script>alert 형태가 없어야 함 (th:utext 영역 ①은 여전히 존재)
    // → owaspSanitized 영역에서는 script 태그가 사라짐
    client.assert(response.body.includes("OWASP"), "OWASP 섹션 존재 기대");
});
%}

###

### [XSS-OWASP-1] POST /students/xss-test — OWASP allowlist 핵심 차이 확인
# 입력: <b>굵은글씨</b><script>alert('XSS')</script>
# URL 인코딩: %3Cb%3E%EA%B5%B5%EC%9D%80%EA%B8%80%EC%94%A8%3C%2Fb%3E%3Cscript%3Ealert%28%27XSS%27%29%3C%2Fscript%3E
#
# 기대 결과:
#   ③ HtmlUtils → &lt;b&gt;굵은글씨&lt;/b&gt;... (b 태그도 이스케이프, 서식 소실)
#   ④ OWASP    → <b>굵은글씨</b>              (b 보존, script 제거)
POST {{baseUrl}}/students/xss-test
Content-Type: application/x-www-form-urlencoded

userInput=%3Cb%3E%EA%B5%B5%EC%9D%80%EA%B8%80%EC%94%A8%3C%2Fb%3E%3Cscript%3Ealert%28%27XSS%27%29%3C%2Fscript%3E

> {%
client.test("200 OK", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("③ HtmlUtils — <b> 태그도 이스케이프됨 (모든 HTML 차단)", function() {
    // HtmlUtils는 <b>도 &lt;b&gt;로 변환 → 서식 소실
    client.assert(response.body.includes("&lt;b&gt;"), "&lt;b&gt; 이스케이프 기대 (HtmlUtils가 b 태그도 차단)");
});
client.test("④ OWASP — <script> 제거되고 <b> 태그는 응답 HTML에 남아있음", function() {
    // OWASP sanitize: <b>굵은글씨</b>는 허용, <script>...는 제거
    // th:utext로 출력하므로 응답 HTML에 <b>굵은글씨</b>가 그대로 존재해야 함
    client.assert(response.body.includes("<b>굵은글씨</b>"), "<b>굵은글씨</b> OWASP 보존 기대");
    client.assert(!response.body.includes("<script>alert"), "<script>alert 제거 기대 (OWASP 방어)");
});
%}


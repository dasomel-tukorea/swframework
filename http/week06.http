### [Lab02-2] POST /students — 학생 등록 (PRG 패턴 확인)
# PRG: HTTP Client는 redirect를 따라가지 않음 → 302 응답 직접 확인
POST {{baseUrl}}/students
Content-Type: application/x-www-form-urlencoded

name=박민준&studentId=202300004&email=park@tukorea.ac.kr

> {%
client.test("302 Redirect (PRG 패턴)", function() {
    client.assert(response.status === 302, "302 Redirect 기대, 실제: " + response.status);
});
client.test("Location 헤더에 /students/{id} 포함", function() {
    const location = response.headers.valueOf("Location");
    client.assert(location !== null && location.includes("/students/"), "Location: /students/{id} 기대, 실제: " + location);
});
%}


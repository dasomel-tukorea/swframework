# ══════════════════════════════════════════════════════════════
# Lab 05 — XSS 방어 (th:text vs th:utext)
# 스크립트 실행 여부는 브라우저에서 직접 확인
# HTTP Client에서는 응답 HTML 소스의 이스케이프 여부 확인
# ══════════════════════════════════════════════════════════════

### [Lab05-1] GET /students/xss-test — 폼 페이지
# URL 우선순위: /xss-test(리터럴) > /{id}(경로변수)
GET {{baseUrl}}/students/xss-test
Accept: text/html

> {%
client.test("200 OK (리터럴 경로 우선 처리)", function() {
    client.assert(response.status === 200, "200 OK 기대 (500이면 /{id}로 잘못 매핑됨)");
});
client.test("XSS 테스트 페이지 제목", function() {
    client.assert(response.body.includes("XSS"), "XSS 페이지 기대");
});
%}

###

### [Lab05-2] POST /students/xss-test — 스크립트 태그 주입
POST {{baseUrl}}/students/xss-test
Content-Type: application/x-www-form-urlencoded

userInput=<script>alert('XSS')</script>

> {%
client.test("상태코드 200", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("th:text 영역 — <script> 이스케이프됨 (안전)", function() {
    // th:text가 적용되면 < > 가 &lt; &gt; 로 변환되어야 함
    client.assert(response.body.includes("&lt;script&gt;"), "&lt;script&gt; 이스케이프 기대 (th:text 정상 동작)");
});
client.test("th:utext 영역 — <script> 그대로 삽입됨 (위험)", function() {
    // th:utext 영역에는 원본 태그가 그대로 존재해야 함
    client.assert(response.body.includes("<script>alert"), "<script> 미이스케이프 확인 (th:utext 위험성)");
});
%}

###

### [Lab05-3] POST /students/xss-test — img onerror XSS
POST {{baseUrl}}/students/xss-test
Content-Type: application/x-www-form-urlencoded

userInput=<img src=x onerror="alert('img XSS')">

> {%
client.test("상태코드 200", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("th:text 영역 — img 태그 이스케이프됨", function() {
    client.assert(response.body.includes("&lt;img"), "&lt;img 이스케이프 기대");
});
%}

###

### [Lab05-4] POST /students/xss-test — 일반 텍스트 (XSS 없음)
POST {{baseUrl}}/students/xss-test
Content-Type: application/x-www-form-urlencoded


### Week 06 — Spring MVC + Thymeleaf 전체 테스트
### IntelliJ HTTP Client: 각 요청 왼쪽 ▶ 버튼으로 개별 실행
### 사전 조건: swframework 앱 실행 (http://localhost:8080)

@baseUrl = http://localhost:8080

# ══════════════════════════════════════════════════════════════
# Lab 01 — REST API (StudentApiController) JSON 응답 확인
# ══════════════════════════════════════════════════════════════

### [Lab01-1] GET /api/hello
GET {{baseUrl}}/api/hello
Accept: application/json

> {%
client.test("상태코드 200", function() {
    client.assert(response.status === 200, "200 OK 기대, 실제: " + response.status);
});
client.test("message 필드 존재", function() {
    client.assert(response.body.message === "안녕하세요!", "message: 안녕하세요! 기대");
});
client.test("course 필드 확인", function() {
    client.assert(response.body.course === "SW프레임워크", "course: SW프레임워크 기대");
});
%}

###

### [Lab01-2] GET /api/students — 전체 학생 목록
GET {{baseUrl}}/api/students
Accept: application/json

> {%
client.test("상태코드 200", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("배열 응답", function() {
    client.assert(Array.isArray(response.body), "배열 형태 기대");
});
client.test("초기 데이터 3건 이상", function() {
    client.assert(response.body.length >= 3, "3건 이상 기대, 실제: " + response.body.length);
});
client.test("studentId 필드 존재 (major 아님)", function() {
    client.assert(response.body[0].studentId !== undefined, "studentId 필드 기대 (major 제거됨)");
    client.assert(response.body[0].major === undefined, "major 필드가 없어야 함");
});
client.test("email 필드 존재", function() {
    client.assert(response.body[0].email !== undefined, "email 필드 기대");
});
%}


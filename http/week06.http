### [XSS-Filter-1] GET /students/filter-test — XSS Servlet Filter 필터 데모 폼
GET {{baseUrl}}/students/filter-test
Accept: text/html

> {%
client.test("200 OK", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("XSS Servlet Filter 데모 페이지", function() {
    client.assert(response.body.includes("XSS Servlet Filter"), "XSS Servlet Filter 페이지 제목 기대");
});
%}


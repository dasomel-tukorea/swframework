### [Lab04-1] H2 Console 접속 (h2 프로필에서만 활성)
GET {{baseUrl}}/h2-console
Accept: text/html

> {%
// h2 프로필이면 200, mysql 프로필이면 LoginInterceptor에 의해 302 또는 404
client.test("응답 도달", () =>
    client.assert([200, 302, 404].includes(response.status)));
%}


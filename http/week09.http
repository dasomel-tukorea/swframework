### Week 09 — Java DB & MyBatis 전체 테스트
### IntelliJ HTTP Client: 각 요청 왼쪽 ▶ 버튼으로 개별 실행
### 본 프로젝트는 W07 LoginInterceptor가 활성이므로 [Login]을 가장 먼저 실행해 세션을 획득해야 한다.
### 사전 조건:
###   MySQL 모드: ./gradlew bootRun --args='--spring.profiles.active=mysql'
###     (도커 컨테이너 비밀번호와 application-mysql.yml의 1234가 다르면
###      SPRING_DATASOURCE_PASSWORD=<실제비번> ./gradlew bootRun ... 으로 오버라이드)
###   H2 모드   : ./gradlew bootRun --args='--spring.profiles.active=h2'

@baseUrl = http://localhost:8080

# ══════════════════════════════════════════════════════════════
# [Login] 세션 획득 (LoginInterceptor 통과)
# ══════════════════════════════════════════════════════════════

### [Login] admin 계정으로 로그인 → JSESSIONID 쿠키 획득
# @no-redirect
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=admin&password=1234

> {%
client.test("로그인 후 redirect", () =>
    client.assert([302, 303].includes(response.status)));
client.test("Location: /students", () =>
    client.assert(response.headers.valueOf("Location").endsWith("/students")));
%}

###

# ══════════════════════════════════════════════════════════════
# Lab 01 — 학생 CRUD 5계층
# ══════════════════════════════════════════════════════════════

### [Lab01-1] 목록 — 3건 표시 (DataInitializer가 초기 3건 INSERT)
GET {{baseUrl}}/students
Accept: text/html

> {%
client.test("상태코드 200", () => client.assert(response.status === 200));
client.test("학생 목록 페이지", () => client.assert(response.body.includes("학생")));
client.test("초기 3건 표시", () =>
    client.assert(response.body.includes("홍길동") &&
                  response.body.includes("김영희") &&
                  response.body.includes("이철수")));
%}

###

### [Lab01-2] 등록 폼
GET {{baseUrl}}/students/new
Accept: text/html

> {%
client.test("폼 페이지", () => client.assert(response.status === 200));
client.test("name input", () => client.assert(response.body.includes('name="name"')));
client.test("studentId input", () => client.assert(response.body.includes('name="studentId"')));
%}

###

### [Lab01-3] 등록 (POST) → PRG 패턴 (302 Redirect → /students/{id})
###   현재 프로젝트의 StudentForm 검증 규칙:
###     name       — NotBlank, 2~20자
###     studentId  — NotBlank, 9자리 숫자
###     email      — 이메일 형식 (선택)
# @no-redirect
POST {{baseUrl}}/students
Content-Type: application/x-www-form-urlencoded

name=박지성&studentId=202300004&email=park@tukorea.ac.kr

> {%
client.test("Redirect 302/303", () =>
    client.assert([302, 303].includes(response.status)));
client.test("Location: /students/{id}", () =>
    client.assert(/\/students\/\d+$/.test(response.headers.valueOf("Location"))));
// 새로 생성된 학생 ID를 다음 요청(Lab01-5)에서 사용하도록 글로벌 변수에 저장
const m = response.headers.valueOf("Location").match(/\/students\/(\d+)$/);
if (m) client.global.set("newStudentId", m[1]);
%}

###

### [Lab01-4] 수정 폼 (id=1)
GET {{baseUrl}}/students/1/edit

> {%
client.test("수정 폼 페이지", () => client.assert(response.status === 200));
client.test("기존 값 prefill", () => client.assert(response.body.includes("홍길동")));
%}

###

### [Lab01-5] 삭제 (직전 [Lab01-3]에서 생성된 newStudentId 사용)
# @no-redirect
POST {{baseUrl}}/students/{{newStudentId}}/delete

> {%
client.test("Redirect", () => client.assert([302, 303].includes(response.status)));
%}

###

# ══════════════════════════════════════════════════════════════
# Lab 03 — Dynamic SQL (검색)
# ══════════════════════════════════════════════════════════════

### [Lab03-1] 이름 검색 — '홍'
GET {{baseUrl}}/students/search?type=name&keyword=홍

> {%
client.test("검색 동작", () => client.assert(response.status === 200));
client.test("홍길동 포함", () => client.assert(response.body.includes("홍길동")));
client.test("타학생 미포함", () =>
    client.assert(!response.body.includes("<td>김영희</td>") &&
                  !response.body.includes("<td>이철수</td>")));
%}

###

### [Lab03-2] 이메일 검색 — 'tukorea'
GET {{baseUrl}}/students/search?type=email&keyword=tukorea

> {%
client.test("이메일 검색", () => client.assert(response.status === 200));
client.test("3건 모두 매칭", () =>
    client.assert(response.body.includes("홍길동") &&
                  response.body.includes("김영희") &&
                  response.body.includes("이철수")));
%}

###

### [Lab03-3] 검색어 없음 — 전체 조회
GET {{baseUrl}}/students/search

> {%
client.test("전체 조회", () => client.assert(response.status === 200));
%}

###

### [Lab03-4] 다건 조회 (foreach IN 절)
GET {{baseUrl}}/students/by-ids?ids=1,2,3

> {%
client.test("다건 조회", () => client.assert(response.status === 200));
client.test("3건 표시", () =>
    client.assert(response.body.includes("홍길동") &&
                  response.body.includes("김영희") &&
                  response.body.includes("이철수")));
%}


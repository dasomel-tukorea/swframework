### [Bonus-1] /api/students JSON 응답
GET {{baseUrl}}/api/students
Accept: application/json

> {%
client.test("API 200", () => client.assert(response.status === 200));
client.test("배열 응답", () => client.assert(Array.isArray(response.body)));
client.test("studentId 필드 존재", () =>
    client.assert(response.body.length === 0 ||
                  response.body[0].hasOwnProperty("studentId")));
%}

###

### [Bonus-2] /api/students/{id} 단건
GET {{baseUrl}}/api/students/1
Accept: application/json

> {%
client.test("단건 200", () => client.assert(response.status === 200));
client.test("name=홍길동", () => client.assert(response.body.name === "홍길동"));
%}


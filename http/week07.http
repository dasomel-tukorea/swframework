# ══════════════════════════════════════════════════════════════
# Lab 04 — BCrypt 비밀번호 암호화 (UserRepository + PasswordUtil)
# 하드코딩 인증 → BCrypt matches() 기반 인증
# 의존성: spring-security-crypto
# ══════════════════════════════════════════════════════════════

### [Lab04-1] POST /login — BCrypt 인증 성공 (admin / 1234)
# UserRepository 생성자에서 PasswordUtil.encode("1234")로 해시 등록
# authenticate() → PasswordUtil.matches("1234", 해시값) → true
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=admin&password=1234

> {%
client.test("302 Redirect (BCrypt 인증 성공)", function() {
    client.assert(response.status === 302, "302 기대 (200이면 BCrypt 인증 실패)");
});
client.test("Location이 /students", function() {
    var location = response.headers.valueOf("Location");
    client.assert(location.includes("/students"), "Location: /students 기대");
});
%}

###

### [Lab04-2] POST /login — BCrypt 인증 성공 (guest / 1234)
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=guest&password=1234

> {%
client.test("302 Redirect (BCrypt 인증 성공)", function() {
    client.assert(response.status === 302, "302 기대");
});
%}

###

### [Lab04-3] POST /login — BCrypt 인증 실패 (잘못된 비밀번호)
# PasswordUtil.matches("wrong", 해시값) → false
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=admin&password=wrong

> {%
client.test("200 OK (인증 실패 → 폼 재렌더링)", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("에러 메시지 포함", function() {
    client.assert(response.body.includes("올바르지 않습니다"), "에러 메시지 기대");
});
%}

###

### [Lab04-4] POST /login — BCrypt 인증 실패 (존재하지 않는 사용자)
# UserRepository.authenticate() → users.get("hacker") == null → false
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=hacker&password=1234

> {%
client.test("200 OK (사용자 없음 → 인증 실패)", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("에러 메시지 포함", function() {
    client.assert(response.body.includes("올바르지 않습니다"), "에러 메시지 기대");
});
%}

###

### [Lab04-5] POST /login — BCrypt 인증: 대소문자 구분 확인
# "Admin" ≠ "admin" — Map 키 비교이므로 대소문자 구분됨
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=Admin&password=1234

> {%

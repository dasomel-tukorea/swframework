### [Lab01-7] POST /logout — 로그아웃 (세션 무효화)
# ⚠️ 먼저 Lab01-2를 실행하여 로그인 상태를 만든 후 실행
POST {{baseUrl}}/logout

> {%
client.test("302 Redirect (로그아웃 후 로그인 페이지로)", function() {
    client.assert(response.status === 302, "302 Redirect 기대, 실제: " + response.status);
});
client.test("Location이 /login으로 리다이렉트", function() {
    var location = response.headers.valueOf("Location");
    client.assert(location !== null && location.includes("/login"), "Location: /login 기대, 실제: " + location);
});
%}


### Week 07 — 세션 & 웹 보안 전체 테스트
### IntelliJ HTTP Client: 각 요청 왼쪽 ▶ 버튼으로 개별 실행
### 사전 조건: swframework 앱 실행 (http://localhost:8080)
### 테스트 계정: admin / 1234, guest / 1234

@baseUrl = http://localhost:8080

# ══════════════════════════════════════════════════════════════
# Lab 01 — HttpSession 로그인/로그아웃 (기본)
# session.setAttribute / getAttribute / invalidate
# ══════════════════════════════════════════════════════════════

### [Lab01-1] GET /login — 로그인 폼 페이지
GET {{baseUrl}}/login
Accept: text/html

> {%
client.test("상태코드 200", function() {
    client.assert(response.status === 200, "200 OK 기대, 실제: " + response.status);
});
client.test("로그인 폼 포함", function() {
    client.assert(response.body.includes("로그인"), "로그인 페이지 제목 기대");
});
client.test("loginId 입력 필드 존재", function() {
    client.assert(response.body.includes('name="loginId"'), "loginId 필드 기대");
});
client.test("password 입력 필드 존재", function() {
    client.assert(response.body.includes('name="password"'), "password 필드 기대");
});
%}

###

### [Lab01-2] POST /login — 로그인 성공 (admin / 1234) → PRG 패턴
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=admin&password=1234

> {%
client.test("302 Redirect (PRG 패턴)", function() {
    client.assert(response.status === 302, "302 Redirect 기대, 실제: " + response.status);
});
client.test("Location이 /students로 리다이렉트", function() {
    var location = response.headers.valueOf("Location");
    client.assert(location !== null && location.includes("/students"), "Location: /students 기대, 실제: " + location);
});
client.test("Set-Cookie 헤더에 JSESSIONID 존재 (세션 생성)", function() {
    var setCookie = response.headers.valueOf("Set-Cookie");
    client.assert(setCookie !== null && setCookie.includes("JSESSIONID"), "JSESSIONID 쿠키 기대");
});
%}

###

### [Lab01-3] POST /login — 로그인 성공 (guest / 1234)
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=guest&password=1234

> {%
client.test("302 Redirect", function() {
    client.assert(response.status === 302, "302 Redirect 기대");
});
client.test("Location이 /students", function() {
    var location = response.headers.valueOf("Location");
    client.assert(location.includes("/students"), "Location: /students 기대");
});
%}

###

### [Lab01-4] POST /login — 로그인 실패 (잘못된 비밀번호)
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=admin&password=wrong

> {%
client.test("200 OK (redirect 아님 — 로그인 실패 시 폼 재렌더링)", function() {
    client.assert(response.status === 200, "200 OK 기대 (302면 인증 로직 오류), 실제: " + response.status);
});
client.test("에러 메시지 포함", function() {
    client.assert(response.body.includes("올바르지 않습니다"), "에러 메시지 기대");
});
%}

###

### [Lab01-5] POST /login — 로그인 실패 (존재하지 않는 아이디)
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=unknown&password=1234

> {%
client.test("200 OK (로그인 실패)", function() {
    client.assert(response.status === 200, "200 OK 기대");
});
client.test("에러 메시지 포함", function() {
    client.assert(response.body.includes("올바르지 않습니다"), "에러 메시지 기대");
});
%}

###

### [Lab01-6] POST /login — 로그인 실패 (빈 값)
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=&password=

> {%
client.test("에러 응답 (400 또는 200 폼 재렌더링)", function() {
    client.assert(response.status === 200 || response.status === 400,
        "200 또는 400 기대, 실제: " + response.status);
});
%}


# ══════════════════════════════════════════════════════════════
# Lab 05 보충 — 세션 쿠키 보안 설정 확인
# application.yml: http-only=true, same-site=lax
# ══════════════════════════════════════════════════════════════

### [Lab05-Cookie-1] POST /login → Set-Cookie 보안 속성 확인
POST {{baseUrl}}/login
Content-Type: application/x-www-form-urlencoded

loginId=admin&password=1234

> {%
client.test("302 Redirect", function() {
    client.assert(response.status === 302, "302 기대");
});
client.test("Set-Cookie에 HttpOnly 속성 (XSS 방어)", function() {
    var setCookie = response.headers.valueOf("Set-Cookie");
    if (setCookie !== null) {
        client.assert(setCookie.toLowerCase().includes("httponly"),
            "HttpOnly 속성 기대 (JavaScript document.cookie 접근 차단)");
    }
});
client.test("Set-Cookie에 SameSite 속성 (CSRF 방어)", function() {
    var setCookie = response.headers.valueOf("Set-Cookie");
    if (setCookie !== null) {
        client.assert(setCookie.toLowerCase().includes("samesite"),
            "SameSite 속성 기대 (외부 도메인 요청 시 쿠키 전송 제어)");
    }
});
%}

###
